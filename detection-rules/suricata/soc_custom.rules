# SOC Lab Custom Suricata Rules
# MITRE ATT&CK mapped network signatures

# T1059.001 — PowerShell download cradle over HTTP
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"SOC | T1059.001 PS DownloadString"; content:"DownloadString"; http_client_body; classtype:trojan-activity; sid:9000001; rev:1;)

# T1557.001 — Responder LLMNR poisoning
alert udp any any -> any 5355 (msg:"SOC | T1557.001 LLMNR Query — Possible Responder"; content:"|00 00 01 00|"; depth:4; classtype:policy-violation; sid:9000002; rev:1;)

# T1071.001 — Cobalt Strike beacon (malleable profile pattern)
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"SOC | T1071 Cobalt Strike Beacon"; content:"/jquery-3.3.1.min.js"; http_uri; content:"__utmz="; http_cookie; classtype:trojan-activity; sid:9000003; rev:1;)

# T1046 — Network scan (many SYN, few ACK)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"SOC | T1046 Port Scan Detected"; flags:S; threshold: type both, track by_src, count 50, seconds 10; classtype:attempted-recon; sid:9000004; rev:1;)

# T1110 — SSH brute force
alert tcp any any -> $HOME_NET 22 (msg:"SOC | T1110 SSH Brute Force"; flow:to_server; threshold: type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:9000005; rev:1;)
